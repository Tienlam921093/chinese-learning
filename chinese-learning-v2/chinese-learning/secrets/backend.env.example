# secrets/backend.env
# Copy file này thành backend.env và điền giá trị thật
# File này KHÔNG được commit lên git
#
# Tạo JWT secrets bằng lệnh:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ── DATABASE ──
DB_USER=sa
DB_PASSWORD=change_this_to_match_sqlserver_env

# ── JWT (bắt buộc — không có fallback) ──
JWT_SECRET=paste_64_char_random_hex_here
JWT_REFRESH_SECRET=paste_another_64_char_random_hex_here
JWT_EXPIRES=15m
JWT_EXPIRES_SECONDS=900

# ── SESSION ──
SESSION_SECRET=paste_another_random_string_here

# ── AI ──
AI_PROVIDER=openai
OPENAI_API_KEY=REPLACE_WITH_REAL_KEY
OPENAI_MODEL=gpt-4o-mini

# Hoặc Anthropic Claude
ANTHROPIC_API_KEY=REPLACE_WITH_REAL_KEY

# ── OAUTH (Google + Facebook) ──
# Hướng dẫn lấy credentials: xem README.md phần OAuth Setup
GOOGLE_CLIENT_ID=REPLACE_WITH_REAL_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_REAL_SECRET
FACEBOOK_APP_ID=REPLACE_WITH_REAL_ID
FACEBOOK_APP_SECRET=REPLACE_WITH_REAL_SECRET

# ── SESSION ──
SESSION_SECRET=REPLACE_WITH_RANDOM_SESSION_SECRET

# ── BASE URL (backend) ──
BASE_URL=http://localhost:5000


# ── VNPAY ──
# Lấy tại: https://sandbox.vnpayment.vn/devreg/
VNPAY_TMN_CODE=REPLACE_WITH_REAL_CODE
VNPAY_HASH_SECRET=REPLACE_WITH_REAL_SECRET
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Production: https://pay.vnpay.vn/vpcpay.html

# ── MOMO ──
# Lấy tại: https://business.momo.vn/
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=REPLACE_WITH_REAL_KEY
MOMO_SECRET_KEY=REPLACE_WITH_REAL_SECRET
# SANDBOX (test)
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create

# PRODUCTION (khi go-live)
# MOMO_API_URL=https://payment.momo.vn/v2/gateway/api/create
# Production: https://payment.momo.vn/v2/gateway/api/create

# URL frontend
FRONTEND_URL=http://localhost:8080

# OAuth redirect URIs cần đăng ký trong Meta/Google dashboard:
#   http://localhost:5000/api/auth/facebook/callback
#   http://localhost:5000/api/auth/google/callback

# Production/ngrok:
# BASE_URL=https://your-backend.example.com
# FRONTEND_URL=https://your-frontend.example.com

# URL public cho VNPay/MoMo (ngrok)
PUBLIC_URL=REPLACE_WITH_PUBLIC_URL

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_real_email@gmail.com
SMTP_PASS=REPLACE_WITH_APP_PASSWORD
EMAIL_PROVIDER=gmail

